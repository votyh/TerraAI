# TerraAI Backend — Environment Variables
# =========================================
# Copy this file to .env (or .env.local) and fill in your real keys.
# NEVER commit a file containing real secrets to version control.
#
# Usage:
#   cp .env.example .env
#   # edit .env with your values
#   uvicorn main:app --reload --port 8000


# ─── Application ──────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins.
# Development default: localhost Next.js dev server
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Secret key used for signing tokens / sessions (generate with: openssl rand -hex 32)
SECRET_KEY=REPLACE_WITH_A_STRONG_RANDOM_SECRET


# ─── Database (PostgreSQL + PostGIS) ──────────────────────────────────────────

# Full async DSN — used by SQLAlchemy (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://terraai_user:REPLACE_PASSWORD@localhost:5432/terraai_db

# Sync DSN — used by Alembic for migrations only
SYNC_DATABASE_URL=postgresql+psycopg2://terraai_user:REPLACE_PASSWORD@localhost:5432/terraai_db


# ─── Rate Limiting ────────────────────────────────────────────────────────────

# Redis URL for distributed rate-limit storage (multi-worker deployments).
# Leave as "memory://" for single-worker local dev; set to your Redis instance in prod.
REDIS_URL=memory://
# Example Redis:  REDIS_URL=redis://localhost:6379/0


# ─── NZ: LINZ Data Service ────────────────────────────────────────────────────
# Register at: https://data.linz.govt.nz/
# Free tier: 1 000 req/day
# Used for: NZ parcel resolution (Layer 50804), property titles (Layer 50772)

LINZ_API_KEY=REPLACE_WITH_LINZ_KEY


# ─── NZ: Auckland Council GIS ─────────────────────────────────────────────────
# Register at: https://data.aucklandcouncil.govt.nz/
# Used for: Auckland flood-hazard overlay, Auckland Unitary Plan zoning polygons

AUCKLAND_COUNCIL_GIS_KEY=REPLACE_WITH_AC_GIS_KEY


# ─── AU: NSW Spatial Services ─────────────────────────────────────────────────
# Register at: https://portal.spatial.nsw.gov.au/
# Used for: NSW address geocoding, cadastre (Lot/DP), land parcel property theme

NSW_SPATIAL_API_KEY=REPLACE_WITH_NSW_SPATIAL_KEY

# PSMA Geocoded National Address File (GNAF) — optional, GNAF is also open-access
# Register at: https://data.gov.au/dataset/ds-dga-19432f89-dc3a-4ef3-b943-5326ef1dbecc
GNAF_API_KEY=REPLACE_WITH_GNAF_KEY


# ─── AU: NSW Planning Portal (LEP Zoning) ─────────────────────────────────────
# Endpoint: https://mappingandwebservices.planning.nsw.gov.au/
# Uses the same NSW_SPATIAL_API_KEY token above; no separate key required.


# ─── AU: NSW Flood Data Portal ────────────────────────────────────────────────
# Register at: https://www.flooddata.nsw.gov.au/
# Uses the same NSW_SPATIAL_API_KEY token above; no separate key required.


# ─── Google APIs ──────────────────────────────────────────────────────────────
# Used for: Maps embed, Sunlight/Topography data (Phase 1 MVP), Street View
# Get a key at: https://console.cloud.google.com/

GOOGLE_MAPS_API_KEY=REPLACE_WITH_GOOGLE_MAPS_KEY


# ─── AI / LLM ────────────────────────────────────────────────────────────────

# Google Gemini 1.5 Pro — primary AI engine for "Dad-Speak" report generation
# Register at: https://aistudio.google.com/
GEMINI_API_KEY=REPLACE_WITH_GEMINI_KEY

# OpenAI GPT-4o — optional fallback
# Register at: https://platform.openai.com/
OPENAI_API_KEY=REPLACE_WITH_OPENAI_KEY


# ─── Email / Notifications ────────────────────────────────────────────────────

# Resend (transactional email for waitlist confirmations)
# Register at: https://resend.com/
RESEND_API_KEY=REPLACE_WITH_RESEND_KEY
EMAIL_FROM=noreply@terraai.co.nz

# Alternatively — SendGrid
# SENDGRID_API_KEY=REPLACE_WITH_SENDGRID_KEY


# ─── Monitoring / Observability (optional) ────────────────────────────────────

# Sentry DSN for error tracking
# SENTRY_DSN=REPLACE_WITH_SENTRY_DSN
