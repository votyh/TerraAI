# ──────────────────────────────────────────────────────────────────────────────
# TerraAI — Environment Variable Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Auckland / NZ Data Sources ─────────────────────────────────────────────
# LINZ (Land Information New Zealand) — authoritative cadastre & property data
# Apply at: https://data.linz.govt.nz/
LINZ_API_KEY=1f542264a3654d749dc4ad9d19cf0356

# Auckland Council Open Data — GIS flood plains, zoning, heritage overlays
# Portal: https://data.aucklandcouncil.govt.nz/
AUCKLAND_COUNCIL_API_KEY=your_auckland_council_key_here

# ── Google Services ─────────────────────────────────────────────────────────
# Google Maps Platform — address autocomplete, Places API, Street View
# Enable: Maps JavaScript API + Places API in Google Cloud Console
# Prefix NEXT_PUBLIC_ makes this available in browser bundle
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# ── AI Services ─────────────────────────────────────────────────────────────
# Google AI Studio — Gemini 1.5 Pro for "Dad-Speak" report generation
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyAP1Ep3_l8SUS_IeWNZLjYKsNVYsDOURIU

# Optional: OpenAI fallback for report generation
# OPENAI_API_KEY=your_openai_key_here

# ── Backend URL (used by Next.js frontend) ───────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── App Config ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ── Supabase (The Brain & Vault) ───────────────────────────────────────────
# Find these in Supabase: Project Settings > API
VITE_SUPABASE_URL=https://xdfhxynofjminpdjkxpu.supabase.co/
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhkZmh4eW5vZmptaW5wZGpreHB1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc4MzMzNzgsImV4cCI6MjA5MzQwOTM3OH0.MKIKtIv60WtED5OHdPzRr9L4lkpqXVI7i1nEkzD8vv0

# ── Stripe (The Cashier) ───────────────────────────────────────────────────
# Find these in Stripe: Developers > API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_key_here